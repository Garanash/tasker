# Секреты не коммитить.
# Docker Compose: создайте `.env` в КОРНЕ репозитория (см. ../.env.example) — переменные попадут в контейнер backend.
# Локальный uvicorn без Docker: скопируйте этот файл в backend/.env и подгрузите через dotenv / export.

# Почта (Mail.ru SMTP): пароль приложения / внешнего клиента — в личном кабинете Mail.ru
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_SSL=1
SMTP_USER=your_mail@mail.ru
SMTP_PASSWORD=
SMTP_FROM_EMAIL=your_mail@mail.ru
SMTP_FROM_NAME=Администратор системы AGB Tasks
