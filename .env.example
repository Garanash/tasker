# Скопируйте в файл `.env` в КОРНЕ репозитория (рядом с docker-compose.yml).
# Файл `.env` в git не попадает — туда вставьте пароль приложения Mail.ru и почту.

# --- SMTP (Mail.ru): пароль приложения в настройках почты → «Пароли для внешних приложений»
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_SSL=1
SMTP_USER=ваш_ящик@mail.ru
SMTP_PASSWORD=пароль_приложения_не_от_аккаунта
SMTP_FROM_EMAIL=ваш_ящик@mail.ru
SMTP_FROM_NAME=Администратор системы AGB Tasks
