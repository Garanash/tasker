# Скопируйте в `.env` в корне репозитория. Docker Compose подставляет переменные автоматически.

# --- Обязательно в проде (docker-compose.prod.yml)
SECRET_KEY=замените_на_длинную_случайную_строку
POSTGRES_PASSWORD=надёжный_пароль_бд
# POSTGRES_DB=kaiten
# POSTGRES_USER=kaiten

# Порт HTTP снаружи (nginx → фронт + API). Для домена без :8080 укажите 80.
# HTTP_PORT=80
# HTTPS (Let's Encrypt на хосте, см. deploy/nginx/default.conf)
# HTTPS_PORT=443
# Email для регистрации в Let's Encrypt (certbot certonly …)
# CERTBOT_EMAIL=you@example.com
# Публичный URL (HTTPS) для ссылок в письмах и CORS
# PUBLIC_APP_URL=https://agbtasker.ru
# CORS_ORIGINS=https://agbtasker.ru,https://www.agbtasker.ru

# Теги образов (прод, docker-compose.prod.yml)
# IMAGE_TAG=latest
# BACKEND_IMAGE_NAME=kaiten-backend
# FRONTEND_IMAGE_NAME=kaiten-frontend

# Локально: URL PostgreSQL (если не Docker)
# DATABASE_URL=postgresql://kaiten:kaiten@localhost:5432/kaiten

# CORS для продакшена (через запятую), если фронт на другом домене
# CORS_ORIGINS=https://app.example.com

# Публичный URL фронта (ссылка «сброс пароля» в письме). Пример: https://tasks.example.com
# PUBLIC_APP_URL=https://tasks.example.com

# --- Локальная разработка (docker-compose.yml): опционально Redis + Celery
# REDIS_URL=redis://127.0.0.1:6379/0
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
# USE_CELERY_BEAT=0

# --- SMTP (Mail.ru и др.)
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_SSL=1
SMTP_USER=ваш_ящик@mail.ru
SMTP_PASSWORD=пароль_приложения
SMTP_FROM_EMAIL=ваш_ящик@mail.ru
SMTP_FROM_NAME=Администратор системы AGB Tasks
